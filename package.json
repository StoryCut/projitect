{
  "name": "projitect-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "projitect monorepo — workspace root (not published)",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "changeset": "changeset",
    "check-all": "pnpm tc && pnpm lint && pnpm test && pnpm knip",
    "format": "prettier --write \"**/*.{md,mdx,yml,yaml,json5,css}\"",
    "kanban:score": "tsx .claude/skills/kanban/scripts/score-backlog.ts",
    "kanban:status": "tsx .claude/skills/kanban/scripts/status-check.ts",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky && effect-language-service patch",
    "release": "pnpm build && changeset publish",
    "tc": "tsc --build",
    "tc:clean": "tsc --build --clean",
    "tc:watch": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{md,mdx,yml,yaml,json5,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.31.0",
    "@effect/language-service": "^0.86.2",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.19",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/eslint-plugin": "1.6.18",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-package-json": "0.39.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unicorn": "56.0.1",
    "husky": "9.1.7",
    "knip": "6.14.2",
    "lint-staged": "15.5.2",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.12.0"
  }
}
