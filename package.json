{
  "name": "projitect-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "projitect monorepo — workspace root (not published)",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "changeset": "changeset",
    "check-all": "pnpm tc && pnpm lint && pnpm test && pnpm knip",
    "format": "prettier --write \"**/*.{md,mdx,yml,yaml,json5,css}\"",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky && effect-language-service patch",
    "release": "pnpm build && changeset publish",
    "tc": "tsc --build",
    "tc:clean": "tsc --build --clean",
    "tc:watch": "tsc --build --watch",
    "test": "vitest run",
    "test:types": "tstyche",
    "test:watch": "vitest",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{md,mdx,yml,yaml,json5,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@effect/language-service": "^0.86.2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.4.0",
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-package-json": "^0.39.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unicorn": "^56.0.0",
    "husky": "^9.1.7",
    "knip": "^6.0.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.0",
    "tstyche": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  }
}
