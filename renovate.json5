/*
 * Renovate configuration for projitect.
 *
 * Extends the org's shared js-lib preset (github>nunofyobiz/renovate-config:js-lib.json5), which
 * layers config:js-lib over the org-wide and shared JS rules — concurrency, scheduling, automerge,
 * prPriority, minimumReleaseAge, platform settings, and Effect ecosystem grouping all live there.
 *
 * Only the projitect-specific overrides remain here:
 *  - Two private workspaces (the workspace root `package.json` and the docs site at
 *    `apps/website/package.json`) pin exact versions instead of keeping js-lib's widened ranges.
 *    Pinning those keeps the team's local builds deterministic without affecting downstream
 *    consumers; every other (published) package keeps js-lib semver-range semantics.
 *  - Astro + typescript-eslint ecosystem grouping (the shared preset only groups Effect).
 */
{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: ["github>nunofyobiz/renovate-config:js-lib.json5", ":semanticCommits"],

  packageRules: [
    /* ******************************************************
     * SECTION: ecosystem grouping
     * (Effect is already grouped by the shared js-base preset.)
     ****************************************************** */
    {
      // Astro + integrations for the docs site
      matchPackageNames: ["/^astro$/", "/^@astrojs\\//"],
      groupName: "Astro ecosystem",
    },
    {
      // typescript-eslint and friends
      matchPackageNames: ["/^typescript-eslint$/", "/^@typescript-eslint\\//"],
      groupName: "typescript-eslint",
    },

    /* ******************************************************
     * SECTION: private-workspace pinning
     * The two private package.jsons get exact-pinning. Everything else stays js-lib semantics.
     ****************************************************** */
    {
      matchFileNames: ["package.json", "apps/website/package.json"],
      rangeStrategy: "pin",
    },
  ],
}
