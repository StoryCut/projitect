{
  "name": "@projitect/internal",
  "version": "0.0.0",
  "private": true,
  "description": "Private, never-published generic utilities (Effect-extension *X modules). Bundled into the published packages at build time.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "tc": "tsc --build"
  },
  "devDependencies": {
    "effect": "^4.0.0-beta.70",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.70"
  }
}
