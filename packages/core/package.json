{
  "name": "@projitect/core",
  "version": "0.0.0",
  "description": "Shared contracts for projitect — Blueprint, ChangeSet, Permission, ProjitectConfig, and the error catalog.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    }
  },
  "files": ["dist", "src", "!**/*.tsbuildinfo"],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "tc": "tsc --build"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.70"
  },
  "devDependencies": {
    "effect": "^4.0.0-beta.70",
    "typescript": "^5.7.0"
  }
}
