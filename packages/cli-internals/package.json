{
  "name": "@projitect/cli-internals",
  "version": "0.0.0",
  "description": "Engine for the projitect CLI — loader, planner, differ, applier, and command dispatchers.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bin": {
      "types": "./dist/bin.d.ts",
      "import": "./dist/bin.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "tc": "tsc --build"
  },
  "dependencies": {
    "@nunofyobiz/effect-extras": "3.0.0"
  },
  "devDependencies": {
    "@projitect/blueprint": "workspace:*",
    "@projitect/core": "workspace:*",
    "@types/node": "22.19.19",
    "effect": "4.0.0-beta.74",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@projitect/blueprint": "workspace:*",
    "@projitect/core": "workspace:*",
    "effect": "4.0.0-beta.74"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
