{
  "name": "@projitect/blueprint-tsconfig",
  "version": "0.0.0",
  "description": "TypeScript tsconfig.json scaffolding blueprint for projitect — strict defaults, owned mode.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "tc": "tsc --build"
  },
  "devDependencies": {
    "@projitect/blueprint": "workspace:*",
    "@projitect/core": "workspace:*",
    "@projitect/test-kit": "workspace:*",
    "effect": "4.0.0-beta.74",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@projitect/blueprint": "workspace:*",
    "@projitect/core": "workspace:*",
    "effect": "4.0.0-beta.74"
  },
  "projitect": {
    "type": "blueprint",
    "import": "import { tsconfig } from \"@projitect/blueprint-tsconfig\"",
    "call": "tsconfig()"
  }
}
